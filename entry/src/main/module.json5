{
  "module": {
    "name": "entry",
    "type": "entry",
    "description": "$string:module_description",
    "mainElement": "DefaultAbility",
    "srcEntry": "./ets/app/App.ts",
    "deviceTypes": [
      "phone"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "name": "DefaultAbility",
        "srcEntry": "./ets/app/DefaultAbility.ts",
        "description": "Default Ability",
        "icon": "$media:layered_image",
        "label": "$string:launcher_name",
        "startWindowIcon": "$media:foreground",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "ohos.want.action.home"
            ]
          }
        ]
      },
      {
        "name": "SecondaryAbility",
        "srcEntry": "./ets/app/SecondaryAbility.ts",
        "description": "Secondary Ability",
        "icon": "$media:layered_image",
        "label": "$string:secondary_ability_label",
        "startWindowIcon": "$media:foreground",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": []
      },
      {
        "name": "LastAbility",
        "srcEntry": "./ets/app/LastAbility.ts",
        "description": "$string:last_ability_label",
        "icon": "$media:layered_image",
        "label": "$string:ability_label",
        "startWindowIcon": "$media:foreground",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": []
      }
    ],
    "extensionAbilities": [
      {
        "name": "BackupAbility",
        "srcEntry": "./ets/app/BackupAbility.ts",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ]
      }
    ]
  },
}
